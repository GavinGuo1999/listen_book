LISTEN_BOOK_DATABASE_URL=postgresql+psycopg://listen_book_app:change-me@localhost:5432/listen_book
LISTEN_BOOK_SECRET_KEY=change-me-in-development
LISTEN_BOOK_BOOTSTRAP_ADMIN_USERNAME=admin
LISTEN_BOOK_BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password
LISTEN_BOOK_STORAGE_ROOT=../storage
LISTEN_BOOK_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LISTEN_BOOK_JOB_RETENTION_DAYS=30
LISTEN_BOOK_JOB_CLEANUP_INTERVAL_SECONDS=3600

# Optional Playwright E2E overrides. Defaults are safe for local tests.
LISTEN_BOOK_E2E_DATABASE_NAME=listen_book_e2e
# Optional explicit E2E URL. SQLite paths must stay under storage/e2e.
# LISTEN_BOOK_E2E_DATABASE_URL=sqlite+pysqlite:///storage/e2e/listen_book_e2e.db
LISTEN_BOOK_E2E_ADMIN_USERNAME=admin
LISTEN_BOOK_E2E_ADMIN_PASSWORD=e2e-admin-password
